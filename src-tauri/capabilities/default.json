{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "default",
  "description": "Default capability for main window — allows remote IPC from sidecar HTTP server",
  "windows": [
    "main"
  ],
  "remote": {
    "urls": [
      "http://127.0.0.1:8765",
      "http://localhost:8765",
      "http://127.0.0.1:5173",
      "http://localhost:5173"
    ]
  },
  "permissions": [
    "core:default",
    "opener:default",
    "opener:allow-open-url",
    "opener:allow-open-path",
    "opener:allow-reveal-item-in-dir"
  ]
}
