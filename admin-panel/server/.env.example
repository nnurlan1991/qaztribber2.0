# QazTriber Admin Panel — environment variables
# Copy to .env and fill with real values. NEVER commit .env.

# Server
PORT=3003
NODE_ENV=production

# JWT secret for magic-link sessions (generate: openssl rand -hex 32)
JWT_SECRET=replace-with-random-64-hex

# Public base URL (for magic links and Telegram)
PUBLIC_URL=https://qaztribber.aidi-lab.kz/admin

# Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# Firebase Admin SDK — path to service account JSON
# On VPS: /home/ai/.config/qaztriber/firebase-service-account.json
GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
FIREBASE_PROJECT_ID=qaztriber
